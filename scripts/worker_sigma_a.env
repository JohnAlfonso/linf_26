# Worker 1 of 3 — σ-zero zeros-init, B=2
# Run as: WORKER_ENV=worker_sigma_a.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_a"
export WORKER_PORT="9201"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
# TF32 on for speed (coordinator re-checks under FP32).
# MPS — share GPU with other workers without serializing.
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
