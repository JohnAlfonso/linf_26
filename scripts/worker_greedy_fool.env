# Worker 15 — GreedyFool (Dong NeurIPS 2020) + MALT target picker
# Hard-image worker for GPU3 (RTX PRO 6000).
#
# Two-stage greedy attack: SELECT pixels via gradient × magnitude to flip,
# then REDUCE by dropping low-cost pixels while preserving flip. Different
# algorithm family from σ-zero — paper reports 3× lower K than SparseFool
# on ImageNet (K=27 vs K=80 at full magnitude).
#
# Pre-stage: MALT-picked top-1 cheapest target (~700ms).
# Stage 1 (SELECT): 8 grad-based grow steps (~1s)
# Stage 2 (REDUCE): up to 20 removal rounds with batched halving (~3-5s)
# Total budget: ~6-7s comfortably within 9.5s deadline.
#
# Run as: WORKER_ENV=worker_greedy_fool.env bash scripts/run_worker.sh
export WORKER_STRATEGY="greedy_fool"
export WORKER_PORT="9228"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
