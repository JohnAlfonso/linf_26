# Worker 14 — σ-zero B=12 + MALT target picker (Lim 2024, arXiv:2407.02240)
# Hard-image worker for GPU3 (RTX PRO 6000, 96GB).
#
# Identical to sigma_max except targets are picked via Jacobian-normalized
# cost ranking (top-30 candidates → top-11 cheapest), instead of raw logit
# ranking. MALT's claim: optimal targets are often ranked 18-52 by logits
# but rank-1 by attack cost. If our 0.9043 floor cases have non-runner-up
# optimal targets, sigma_max_malt should beat sigma_max on them.
#
# A/B against sigma_max (port 9224) — same B=12, same iters, only target
# selection differs.
#
# Run as: WORKER_ENV=worker_sigma_max_malt.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_max_malt"
export WORKER_PORT="9226"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
