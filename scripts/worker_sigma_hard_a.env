# Worker 9 of 11 — σ-zero B=8 zeros-init, n_iter=400
# Hard-image worker for GPU3 (RTX PRO 6000, 96GB)
# Upgraded from B=4→8 to use larger VRAM for more parallel Pareto-K targets.
# Run as: WORKER_ENV=worker_sigma_hard_a.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_hard_a"
export WORKER_PORT="9221"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
