# Worker 10 of 11 — σ-zero B=4 random seed=99, n_iter=400
# Hard-image-only worker for GPU3 (RTX 3090, 24GB)
# Run as: WORKER_ENV=worker_sigma_hard_b.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_hard_b"
export WORKER_PORT="9222"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
