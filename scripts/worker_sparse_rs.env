# Worker 4 of 4 — σ-zero seed + Sparse-RS refinement (lower GPU than σ-zero alone)
# Phase 1: brief σ-zero (B=1, 80 iters) for seed adv
# Phase 2: random local search (forward-only) for K minimization
# Run as: WORKER_ENV=worker_sparse_rs.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sparse_rs"
export WORKER_PORT="9205"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="11"
# MPS — share GPU with other workers without serializing.
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
