# Worker 14 — σ-zero B=1 single MALT-picked target, n=900 (deep K grind)
# Hard-image worker for GPU3 (RTX PRO 6000).
#
# Designed to attack the structural K gap on easy images: top miners ship
# K~15-25 (rmse ~0.000200), our multi-target σ-zero plateaus at K~40-50
# (rmse ~0.000400). B=1 single-target with n=900 should drive K below
# what multi-target setups can reach (Pintor 2024: multi-target plateaus
# higher because targets compete for the same pixel budget).
#
# Pre-stage: MALT-picked top-1 cheapest target (~700ms).
# Main loop: B=1 × 900 iters ≈ 8.5s on RTX PRO 6000.
#
# Run as: WORKER_ENV=worker_sigma_grind.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_grind"
export WORKER_PORT="9206"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="10.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
