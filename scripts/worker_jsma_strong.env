# Worker 11 of 11 — JSMA with backward_eliminate=True (low K, slow)
# Hard-image-only worker for GPU3 (RTX 3090, 24GB)
# Note: ~15-25s under MPS contention. Acceptable because hard-only.
# Run as: WORKER_ENV=worker_jsma_strong.env bash scripts/run_worker.sh
export WORKER_STRATEGY="jsma_strong"
export WORKER_PORT="9223"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
