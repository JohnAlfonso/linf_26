# Worker — sigma_grind_c: σ-zero B=1, MALT top-1 target, RANDOM init (seed=42), n=900
# Same target as sigma_grind but starts from a different basin via random init.
# Single-target σ-zero's local minimum depends on initialization;
# zeros-init and random-init reach different basins on the same image.
# Together with sigma_grind (top-1 zeros) and sigma_grind_b (top-2 zeros),
# forms a 3-restart B=1 grind ensemble.
#
# Run as: WORKER_ENV=worker_sigma_grind_c.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_grind_c"
export WORKER_PORT="9230"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
