# Worker — pgd_high_k: PGD at fixed K=150 with margin-max loss
# RESCUE WORKER for extreme hard images (gap > 5) where the σ-zero family
# fails to flip at all. Top miners ship K=115-170 on such cases for score
# ~0.92; this worker matches that regime.
#
# Won't compete on easy images (K=150 >> sigma_a's K=30-50) but
# RELIABLY produces flipping candidates on the 1-2% of extreme-hard
# images where everything else returns score=0.
#
# Run as: WORKER_ENV=worker_pgd_high_k.env bash scripts/run_worker.sh
export WORKER_STRATEGY="pgd_high_k"
export WORKER_PORT="9231"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
