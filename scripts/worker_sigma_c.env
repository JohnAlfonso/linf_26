# Worker 5 of 8 — σ-zero zeros-init, B=8 (huge batch, max Pareto-K)
# Designed for GPU2 (RTX PRO 6000) with VRAM headroom.
# Run as: WORKER_ENV=worker_sigma_c.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_c"
export WORKER_PORT="9211"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
