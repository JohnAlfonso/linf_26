# Worker 2 of 3 — σ-zero random-init, B=4 (higher VRAM, more diversity)
# Run as: WORKER_ENV=worker_sigma_b.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_b"
export WORKER_PORT="9202"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="10.5"
# MPS — share GPU with other workers without serializing.
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
