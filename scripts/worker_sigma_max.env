# Worker 12 of 12 — σ-zero B=12 zeros-init, n_iter=300 (MAX parallel Pareto)
# Hard-image worker for GPU3 (RTX PRO 6000, 96GB)
# Uses ~24 GB VRAM alone — biggest worker we run.
# 12 parallel target classes per iteration = deepest Pareto-K coverage.
# Run as: WORKER_ENV=worker_sigma_max.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_max"
export WORKER_PORT="9224"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
