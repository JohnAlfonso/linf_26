# Worker — sigma_grind_b: σ-zero B=1, MALT top-2 target, n=900
# Companion to sigma_grind that attacks the SECOND-cheapest target.
# MALT's top-1 isn't always optimal; running parallel grinds on top-1 and
# top-2 gives two independent low-K candidates. Coordinator picks the best.
#
# Run as: WORKER_ENV=worker_sigma_grind_b.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sigma_grind_b"
export WORKER_PORT="9229"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
