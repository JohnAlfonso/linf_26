# Worker 13 — Sparse-PGD (Zhong 2024) + MALT target picker (Lim 2024)
# Hard-image worker for GPU3 (RTX PRO 6000, 96GB).
#
# Sparse-PGD = binary mask + sign-only magnitude PGD with random mask
# re-init on stagnation. Designed for L∞=1/255 sparse adversarial budgets.
# Different algorithm family from σ-zero — escapes basins where σ-zero
# soft-L0 mask gets stuck (the 0.0000-ship `label_match_with_original`
# cases).
#
# MALT pre-stage: re-ranks top-20 runner-ups by Jacobian-normalized cost,
# picks the cheapest 2 as targets. ~700ms overhead, then ~45 PGD iters.
#
# Run as: WORKER_ENV=worker_sparse_pgd.env bash scripts/run_worker.sh
export WORKER_STRATEGY="sparse_pgd"
export WORKER_PORT="9225"
export WORKER_HOST="0.0.0.0"
export WORKER_DEADLINE_S="9.5"
export CUDA_MPS_PIPE_DIRECTORY=/tmp/nvidia-mps
export CUDA_MPS_LOG_DIRECTORY=/tmp/nvidia-log
