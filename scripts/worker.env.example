# Copy to scripts/worker.env on EACH GPU server and customize.
# All vars below MUST start with `export` so PM2 inherits them.

# Which attack this server runs. Each of the 3 servers should use a
# DIFFERENT value — diversity beats N× same-attack.
#   sigma_a — σ-zero zeros-init, B=2, N=300  (recommended for GPU 1)
#   sigma_b — σ-zero random-init, B=4, N=240 (recommended for GPU 2)
#   jsma    — JSMA-greedy cluster_kernel=3   (recommended for GPU 3)
export WORKER_STRATEGY="sigma_a"

# Port the worker listens on. Coordinator will dial this.
export WORKER_PORT="9200"

# Bind interface. 0.0.0.0 allows external connections. Use 127.0.0.1
# only if coordinator runs on the same host.
export WORKER_HOST="0.0.0.0"

# Per-request attack budget. Should be slightly LESS than the
# coordinator's worker timeout to give the worker time to respond.
export WORKER_DEADLINE_S="9.0"

# TF32 is ON by default in workers (~25% faster σ-zero on RTX). The
# coordinator re-checks flip with FP32-strict before shipping, so
# label_match-style failures from cross-precision noise don't reach
# the validator. Set to 1 only if you also want strict FP32 on
# workers (slower but the coordinator's check then has no effect).
# export WORKER_DISABLE_TF32="0"

# Python interpreter override.
# export PYTHON_BIN="python3"
